# Copy to .env and fill in your values
# DEPLOYER_PRIVATE_KEY is loaded from Replit Secrets automatically

# Network RPC URLs
RPC_URL_LOCALHOST=http://localhost:8545
RPC_URL_SEPOLIA=https://rpc.sepolia.org
RPC_URL_MAINNET=https://mainnet.infura.io/v3/YOUR_INFURA_KEY

# Optional: override mint price (in wei, default 0.01 ETH)
# MINT_PRICE=10000000000000000
